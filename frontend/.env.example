# React app environment variables
REACT_APP_API_URL=http://localhost:3001
REACT_APP_API_BASE_URL=http://localhost:3001/api/v1

# Keycloak Configuration
REACT_APP_KEYCLOAK_URL=http://localhost:8080
REACT_APP_KEYCLOAK_REALM=cms-realm
REACT_APP_KEYCLOAK_CLIENT_ID=cms-frontend

# Enable Keycloak (set to true after setup)
REACT_APP_USE_KEYCLOAK=true

# Database Configuration (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=cms_database
DB_USER=cms_user
DB_PASSWORD=cms_password123
DB_ROOT_PASSWORD=root123

# phpMyAdmin Configuration
PHPMYADMIN_PORT=8081

# Optional: For production
# REACT_APP_API_URL=https://your-production-api.com
# REACT_APP_API_BASE_URL=https://your-production-api.com/api/v1
# REACT_APP_KEYCLOAK_URL=https://your-keycloak-server.com
# REACT_APP_KEYCLOAK_REALM=production-realm
# REACT_APP_KEYCLOAK_CLIENT_ID=cms-frontend-prod
# DB_HOST=your-production-db-host
# DB_NAME=your-production-db-name
# DB_USER=your-production-db-user
# DB_PASSWORD=your-production-db-password
